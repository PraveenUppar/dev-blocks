generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  NEW_FOLLOWER
  POST_LIKED
  POST_COMMENTED
  COMMENT_REPLIED
  MENTION
}

// ==================== MODELS ====================

model User {
  // Basic Info
  id       String  @id @default(uuid())
  email    String  @unique
  username String  @unique
  name     String?
  bio      String?
  avatar   String?
  
  // Authentication (using Clerk)
  clerkId  String  @unique  
  role     UserRole @default(USER)
  
  // Social Links
  website  String?
  twitter  String?
  github   String?
  linkedin String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  notifications    Notification[]
  readingHistories ReadingHistory[]
  bookmarks        Bookmark[]
  followers        Follow[] @relation("followers")
  following        Follow[] @relation("following")

  // Indexes
  @@index([email])
  @@index([username])
  @@index([clerkId])
}

model Post {
  // Content Info
  id         String  @id @default(uuid())
  title      String
  subtitle   String?
  content    String
  slug       String  @unique
  coverImage String?
  
  // Metadata
  readTime   Int?    @default(0)  // Changed: Made optional, added default
  viewCount  Int     @default(0)
  readCount  Int     @default(0)
  
  // Publishing
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  deletedAt   DateTime?  // Added: For soft deletes
  
  // SEO (optional)
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  authorId         String
  author           User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments         Comment[]
  likes            Like[]
  tags             PostTag[]
  bookmarks        Bookmark[]
  readingHistories ReadingHistory[]

  // Indexes
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([slug])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Moderation
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  
  // Threading (replies)
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
  
  // Relations
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@index([parentId])  // Added: For fetching replies
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique  // Added: For SEO-friendly URLs
  createdAt DateTime @default(now())

  // Relations
  posts PostTag[]
  
  // Indexes
  @@index([name])  // Added: For autocomplete
  @@index([slug])  // Added: For URL lookups
}

model PostTag {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
}

model Follow {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  followerId  String
  follower    User   @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User   @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Bookmark {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  
  // Recipient
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Related entities (optional)
  actorId   String?
  postId    String?
  commentId String?
  
  // Indexes
  @@index([userId, read])
  @@index([userId, createdAt])
}

model ReadingHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  // Engagement Metrics
  timeSpent   Int // Seconds
  scrollDepth Int // Percentage (0-100)
  
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}